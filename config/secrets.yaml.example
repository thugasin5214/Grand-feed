# IntelFeed Secrets Configuration
# Copy this file to secrets.yaml and fill in your API keys

openrouter:
  api_key: "sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE"

email:
  smtp_host: smtp.gmail.com
  smtp_port: 587
  sender: "your-email@gmail.com"
  password: "your-app-specific-password"  # For Gmail, use App Password

newsapi:
  api_key: "YOUR_NEWSAPI_KEY_HERE"  # Get from https://newsapi.org

